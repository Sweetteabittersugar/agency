{
  "version": "0.2.0",
  "description": "Profile 三级制度 — 面向用户体验设计，控制上下文窗口、Token 预算和可用功能",
  "profiles": {
    "minimal": {
      "max_tokens": 16384,
      "description": "省流模式 — 日常查询、简单编辑，约支持 20 轮对话",
      "agents": ["router"],
      "skills": [],
      "hooks": ["SessionStart"],
      "trigger": "单文件读写、grep搜索、状态查询、简单问答",
      "conditions": {
        "max_files": 1,
        "max_steps": 1,
        "allow_write": false
      }
    },
    "standard": {
      "max_tokens": 65536,
      "description": "标准模式 — 正常开发、多文件修改，约支持 80 轮对话",
      "agents": ["router", "coder", "code-reviewer", "test-runner", "explorer", "security-reviewer", "devops", "designer", "debugger", "general-worker", "orchestrator", "planner"],
      "skills": ["按需匹配"],
      "hooks": ["SessionStart", "SubagentStop"],
      "trigger": "日常开发、2-5文件修改、代码审查、写测试",
      "conditions": {
        "max_files": 5,
        "max_steps": 5,
        "allow_write": true
      }
    },
    "full": {
      "max_tokens": 131072,
      "description": "深度模式 — 复杂重构、架构设计，约支持 160 轮对话",
      "agents": ["全部 32 个 Agent（12 大类）"],
      "skills": ["全部匹配"],
      "hooks": ["全部"],
      "trigger": "复杂重构、架构设计、多模块联动、管线编排",
      "conditions": {
        "max_files": 999,
        "max_steps": 999,
        "allow_write": true
      }
    }
  }
}
