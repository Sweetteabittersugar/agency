{
  "env": {
    "CLAUDE_CODE_ATTRIBUTION_HEADER": "0"
  },
  "claudeMdExcludes": [
    "**/node_modules/**/CLAUDE.md",
    "**/.git/**/CLAUDE.md"
  ],
  "attribution": {
    "commit": "Co-authored-by: Claude Code <noreply@anthropic.com>"
  },
  "includeCoAuthoredBy": false,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/SessionStart.py"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/SubagentStop.py"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/PreCompact.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/Stop.py"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/Notification.py"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "test"
    ]
  },
  "test": true
}