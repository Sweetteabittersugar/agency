# ============================================
# Agency 模型配置
# ============================================

# 选择提供者（小写）
PROVIDER=deepseek
# 可选: deepseek | openai | anthropic | gemini | qwen | zhipu | moonshot | ollama

# === DeepSeek ===
DEEPSEEK_API_KEY=sk-xxxxxxxx

# === OpenAI ===
# OPENAI_API_KEY=sk-xxxxxxxx

# === Anthropic (Claude) ===
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# === Google Gemini ===
# GEMINI_API_KEY=xxxxxxxx

# === 阿里通义千问 ===
# QWEN_API_KEY=sk-xxxxxxxx

# === 智谱 GLM ===
# ZHIPU_API_KEY=xxxxxxxx

# === Moonshot ===
# MOONSHOT_API_KEY=sk-xxxxxxxx

# === 本地 Ollama ===
# OLLAMA_BASE_URL=http://localhost:11434/v1

# === 自定义 OpenAI 兼容端点 ===
# CUSTOM_API_KEY=sk-xxxxxxxx
# BASE_URL=https://your-api.com/v1

# ============================================
# 模型映射（可选，覆盖预设）
# ============================================
# Agent 的能力级别 → 具体模型名
# 不配则自动降级：opus→sonnet→haiku→DEFAULT_MODEL
# HEAVY_MODEL=deepseek-v4-pro      # opus 级 Agent 用
# STANDARD_MODEL=deepseek-v4-pro   # sonnet 级 Agent 用
# LIGHT_MODEL=deepseek-v4-flash    # haiku 级 Agent 用
# DEFAULT_MODEL=deepseek-v4-pro    # 终极降级

# === Claude Code ===
# Claude Code 配置目录（默认 ~/.claude）
# CLAUDE_CONFIG_DIR=~/.claude

# === 成本追踪 ===
# 每日费用上限（元），超出后自动降级到低成本模型
# COST_DAILY_BUDGET=50
# 每月费用上限（元）
# COST_MONTHLY_BUDGET=500

# === 日志 ===
# 日志级别: DEBUG / INFO / WARNING / ERROR
# LOG_LEVEL=INFO
