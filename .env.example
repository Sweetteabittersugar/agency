# === 模型提供者（选一个） ===
# DeepSeek（默认）
DEEPSEEK_API_KEY=sk-xxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI 兼容（任何兼容 OpenAI API 的服务）
# OPENAI_API_KEY=sk-xxxxxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# 本地 Ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1

# === 模型设置 ===
# 默认模型（自动路由用）
DEFAULT_MODEL=deepseek-chat
# 推理模型（planner/复杂任务用）
REASONING_MODEL=deepseek-reasoner
# haiku 级 agent 映射到的模型（explorer, cost-analyst 等）
LIGHT_MODEL=deepseek-chat
# sonnet 级 agent 映射到的模型
STANDARD_MODEL=deepseek-chat
# opus 级 agent 映射到的模型
HEAVY_MODEL=deepseek-reasoner

# === Claude Code ===
# Claude Code 配置目录（默认 ~/.claude）
# CLAUDE_CONFIG_DIR=~/.claude

# === Maestro ===
# 项目根目录（默认当前工作目录）
# CLAUDE_PROJECT_DIR=.

# === 成本追踪 ===
# 每日费用上限（元），超出后自动降级到低成本模型
# COST_DAILY_BUDGET=50
# 每月费用上限（元）
# COST_MONTHLY_BUDGET=500

# === 日志 ===
# 日志级别: DEBUG / INFO / WARNING / ERROR
# LOG_LEVEL=INFO
