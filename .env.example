# agency-kit 环境变量配置
# 复制此文件为 .env 并填入实际值

# === Claude Code ===
# Claude Code 配置目录（默认 ~/.claude）
# CLAUDE_CONFIG_DIR=~/.claude

# === DeepSeek API ===
# DeepSeek API 密钥（独立运行 entry 和 Maestro 调度共用）
DEEPSEEK_API_KEY=sk-xxxxxxxx
# DeepSeek API 密钥（用于 reasonix 调度，兼容旧配置）
# REASONIX_API_KEY=sk-xxxxxxxx

# === Maestro ===
# 项目根目录（默认当前工作目录）
# CLAUDE_PROJECT_DIR=.

# === 成本追踪 ===
# 每日费用上限（元），超出后自动降级到低成本模型
# COST_DAILY_BUDGET=50
# 每月费用上限（元）
# COST_MONTHLY_BUDGET=500

# === 日志 ===
# 日志级别: DEBUG / INFO / WARNING / ERROR
# LOG_LEVEL=INFO
